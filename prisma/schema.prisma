generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("FARMER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model AgriculturalInput {
  id          String   @id @default(cuid())
  name        String
  type        String   // "SEED" or "FERTILIZER"
  price       Float
  stock       Int      // Available bulk stock units
  location    String?  // Added for seller location
  imageUrl    String?  // Added for catalog image
  size        String?  // Added for dimension scoping
  weight      String?  // Added for specific weight thresholds
  brand       String?  // Added for Input Brand Identity
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Float
  status      String      @default("PENDING") // PENDING, PAID, DELIVERED
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String            @id @default(cuid())
  orderId   String
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inputId   String
  input     AgriculturalInput @relation(fields: [inputId], references: [id])
  quantity  Int
  price     Float
}
